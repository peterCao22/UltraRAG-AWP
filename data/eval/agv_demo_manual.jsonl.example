{"id": "eval_agv_demo_manual_001", "kb_id": "agv_demo", "query": "AGV 启动前要做哪些检查？", "relevant_chunk_ids": ["BatteryChangeSequenceSOP_intro"], "gold_answer": "检查电池电量、急停按钮、传感器状态、控制台连接", "tags": ["pre_check"], "source": "manual"}
{"id": "eval_agv_demo_manual_002", "kb_id": "agv_demo", "query": "换电池第一步要做什么？", "relevant_chunk_ids": ["BatteryChangeSequenceSOP_step_1"], "gold_answer": "按 7 号键导航 AGV 到空电池仓", "tags": ["step_query"], "source": "manual"}
{"id": "eval_agv_demo_manual_003", "kb_id": "agv_demo", "query": "换电池一共多少步？", "relevant_chunk_ids": ["BatteryChangeSequenceSOP_intro"], "gold_answer": "共 11 步，从拆电池到 Master Link Down 清除", "tags": ["step_count", "multi_step"], "source": "manual"}
{"id": "eval_agv_demo_manual_004", "kb_id": "agv_demo", "query": "ID 01 是什么告警？", "relevant_chunk_ids": ["E-Stop SOP_intro"], "gold_answer": "E-Stop Button Active，急停按钮被按下导致 AGV 停止", "tags": ["error_code"], "source": "manual"}
{"id": "eval_agv_demo_manual_005", "kb_id": "agv_demo", "query": "E-Stop Button Active 怎么处理？", "relevant_chunk_ids": ["E-Stop SOP_intro"], "gold_answer": "检查两侧急停按钮，按下后顺时针旋转复位", "tags": ["error_code", "fix_procedure"], "source": "manual"}
{"id": "eval_agv_demo_manual_006", "kb_id": "agv_demo", "query": "电池电量低怎么办？", "relevant_chunk_ids": ["Alarm Block Battery Low SOP_section_2"], "gold_answer": "按下 AGV 正面 Up/Down 按钮升起电池块", "tags": ["faq", "fix_procedure"], "source": "manual"}
{"id": "eval_agv_demo_manual_007", "kb_id": "agv_demo", "query": "AGV 切换到自动模式的步骤", "relevant_chunk_ids": ["Right Arm FTC SOP_section_3"], "gold_answer": "依次按蓝色按钮、绿色按钮", "tags": ["step_query"], "source": "manual"}
{"id": "eval_agv_demo_manual_008", "kb_id": "agv_demo", "query": "Front PLS 报错怎么办？", "relevant_chunk_ids": ["Front PLS SOP_intro"], "gold_answer": "检查前方激光扫描器，清除遮挡物，按蓝绿按钮复位", "tags": ["error_code", "fix_procedure"], "source": "manual"}
{"id": "eval_agv_demo_manual_009", "kb_id": "agv_demo", "query": "AGV 进不去系统怎么处理？", "relevant_chunk_ids": ["Cannot Enter System SOP_section_2"], "gold_answer": "检查 Master Link、确认 IP 配置、重启 AGV 控制台", "tags": ["fix_procedure"], "source": "manual"}
{"id": "eval_agv_demo_manual_010", "kb_id": "agv_demo", "query": "Master Link Down 怎么消除？", "relevant_chunk_ids": ["Master Link Down SOP_section_1"], "gold_answer": "等 AGV 重连系统，按蓝绿按钮，状态自动清除", "tags": ["error_code", "fix_procedure"], "source": "manual"}
{"id": "eval_agv_demo_manual_011", "kb_id": "agv_demo", "query": "How to handle E-Stop Button Active alarm?", "relevant_chunk_ids": ["E-Stop SOP_intro"], "gold_answer": "Check both E-stop buttons on left and right sides, rotate clockwise to release", "tags": ["error_code", "english_query"], "source": "manual"}
{"id": "eval_agv_demo_manual_012", "kb_id": "agv_demo", "query": "Battery change procedure overview", "relevant_chunk_ids": ["BatteryChangeSequenceSOP_intro"], "gold_answer": "Navigate AGV to empty bay, lower battery block, slide out old battery, swap connectors, install new battery, restart AGV", "tags": ["multi_step", "english_query"], "source": "manual"}
