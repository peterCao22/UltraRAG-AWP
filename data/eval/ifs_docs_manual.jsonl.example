{"id": "eval_ifs_docs_manual_001", "kb_id": "ifs_docs", "query": "如何在 IFS 中创建一家新公司？", "relevant_chunk_ids": ["IFS 系统培训手册--公司人员基础数据_section_2"], "gold_answer": "企业-公司创建-公司导向，输入公司编码和名称，选择模板，按 Finish 完成", "tags": ["how_to"], "source": "manual"}
{"id": "eval_ifs_docs_manual_002", "kb_id": "ifs_docs", "query": "IFS 创建公司时记账货币怎么设？", "relevant_chunk_ids": ["IFS 系统培训手册--公司人员基础数据_section_2"], "gold_answer": "在 Accounting Currency 字段点击左下角 List 键选择调用", "tags": ["faq", "config"], "source": "manual"}
{"id": "eval_ifs_docs_manual_003", "kb_id": "ifs_docs", "query": "公司类型保存后还能改吗？", "relevant_chunk_ids": ["IFS 系统培训手册--公司人员基础数据_section_3"], "gold_answer": "不能，公司类型保存后不可修改", "tags": ["faq", "limitation"], "source": "manual"}
{"id": "eval_ifs_docs_manual_004", "kb_id": "ifs_docs", "query": "IFS 客户端 404 错误怎么处理？", "relevant_chunk_ids": ["IFSSOP_section_1"], "gold_answer": "检查 server URL 与 VPN 状态，确认网络连通", "tags": ["error_code", "fix_procedure"], "source": "manual"}
{"id": "eval_ifs_docs_manual_005", "kb_id": "ifs_docs", "query": "怎么在 IFS 里登录中间层？", "relevant_chunk_ids": ["IFSSOP_section_2"], "gold_answer": "选择中间层服务器、输入账号密码、点击登录", "tags": ["how_to"], "source": "manual"}
{"id": "eval_ifs_docs_manual_006", "kb_id": "ifs_docs", "query": "在系统中处理零件补回登记需要哪些信息？", "relevant_chunk_ids": ["IFS 系统培训手册--公司人员基础数据_section_1"], "gold_answer": "输入手工库存事件类型 wm_type、调整原因 Note、明细数量；任何 WDR 都不参考", "tags": ["how_to", "from_gemini"], "source": "manual"}
{"id": "eval_ifs_docs_manual_007", "kb_id": "ifs_docs", "query": "如何把一个零件从一个库位移到另一个库位？", "relevant_chunk_ids": ["IFS 系统培训手册--公司人员基础数据_section_2"], "gold_answer": "选中库存右键-改变库存位置-新建移库记录-录入移库数量-选择来源和目标库位-保存", "tags": ["how_to", "multi_step"], "source": "manual"}
{"id": "eval_ifs_docs_manual_008", "kb_id": "ifs_docs", "query": "IFS 报销审批流程是怎样的？", "relevant_chunk_ids": ["IFSSOP_section_4"], "gold_answer": "员工提交报销单 → 部门主管审核 → 财务审核 → 出纳支付", "tags": ["multi_step", "process"], "source": "manual"}
{"id": "eval_ifs_docs_manual_009", "kb_id": "ifs_docs", "query": "How to create a new company in IFS?", "relevant_chunk_ids": ["IFS 系统培训手册--公司人员基础数据_section_2"], "gold_answer": "Navigate to Enterprise > Company > Create Company Wizard, input company code and name, select template, click Finish", "tags": ["how_to", "english_query"], "source": "manual"}
{"id": "eval_ifs_docs_manual_010", "kb_id": "ifs_docs", "query": "IFS 客户端无法登录的几种原因？", "relevant_chunk_ids": ["IFSSOP_section_1", "IFSSOP_section_2"], "gold_answer": "网络不通、VPN 未开、账号密码错、中间层服务器地址错、客户端版本不兼容", "tags": ["faq", "troubleshoot"], "source": "manual"}
