# 复制为 .env 后按需填写（.env 已被 gitignore）

GOOGLE_API_KEY=

# 文本生成后端：openai（默认，vLLM/OpenAI 兼容）或 gemini（Google AI，与 GOOGLE_API_KEY 共用）
# ULTRARAG_CHAT_BACKEND=gemini
# 若回答与所选知识库不符：检查浏览器地址栏是否残留 #session=（会按会话所属 kb 自动切库）；或看 Flask 日志 chat_stream kb_id=
# ULTRARAG_GEMINI_MODEL=gemini-2.0-flash
# ULTRARAG_GEMINI_API_KEY=   # 可选；不设则用 GOOGLE_API_KEY
# ULTRARAG_GEMINI_API_HOST=https://generativelanguage.googleapis.com  # 一般不改；Vertex 时再换

# custom_app RAG：OpenAI 兼容生成端（vLLM / 网关）。设置后覆盖 servers/generation/parameter.yaml 中 openai 段。
# ULTRARAG_OPENAI_BASE_URL=http://192.168.8.44:8800/v1
# ULTRARAG_OPENAI_MODEL=Qwen/Qwen3.6-27B-FP8
# ULTRARAG_OPENAI_API_KEY=dummy
# ULTRARAG_OPENAI_REQUEST_TIMEOUT_SEC=300
