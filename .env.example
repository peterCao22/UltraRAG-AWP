# 复制为 .env 后按需填写（.env 已被 gitignore）

GOOGLE_API_KEY=

# 文本生成后端：openai（默认，vLLM/OpenAI 兼容）或 gemini（Google AI，与 GOOGLE_API_KEY 共用）
# ULTRARAG_CHAT_BACKEND=gemini
# 若回答与所选知识库不符：检查浏览器地址栏是否残留 #session=（会按会话所属 kb 自动切库）；或看 Flask 日志 chat_stream kb_id=
# ULTRARAG_GEMINI_MODEL=gemini-2.0-flash
# ULTRARAG_GEMINI_API_KEY=   # 可选；不设则用 GOOGLE_API_KEY
# ULTRARAG_GEMINI_API_HOST=https://generativelanguage.googleapis.com  # 一般不改；Vertex 时再换

# custom_app RAG：OpenAI 兼容生成端（vLLM / 网关）。设置后覆盖 servers/generation/parameter.yaml 中 openai 段。
# ULTRARAG_OPENAI_BASE_URL=http://192.168.8.44:8800/v1
# ULTRARAG_OPENAI_MODEL=Qwen/Qwen3.6-27B-FP8
# ULTRARAG_OPENAI_API_KEY=dummy
# ULTRARAG_OPENAI_REQUEST_TIMEOUT_SEC=300

# ── Phase 5：存储栈迁移 ──────────────────────────────────────────────────────
# Qdrant 向量库（局域网 Docker，默认 6333 端口；无 API key 时留空）
# ULTRARAG_QDRANT_URL=http://192.168.8.40:6333
# ULTRARAG_QDRANT_API_KEY=
# ULTRARAG_QDRANT_COLLECTION_PREFIX=custom_app
# ULTRARAG_QDRANT_TIMEOUT_SEC=30

# PostgreSQL 元数据库（局域网 Docker；密码中特殊字符需 URL-encode：@→%40 #→%23 ! 保留）
# 项目专用数据库 awprag（全小写）；如果使用其他库名替换末尾 /<dbname>
# 首次使用需手动创建：psql -h <host> -U postgres -c 'CREATE DATABASE awprag ENCODING UTF8'
# ULTRARAG_POSTGRES_URI=postgresql://postgres:PASS@192.168.x.x:5432/awprag

# 后端切换（默认 faiss + sqlite，Phase 5 硬切日改成 qdrant / postgres）
# 也可在 servers/retriever/parameter.yaml 的 vector_backend 字段覆盖
# ULTRARAG_VECTOR_BACKEND=faiss    # faiss | qdrant
# ULTRARAG_DB_BACKEND=sqlite        # sqlite | postgres
